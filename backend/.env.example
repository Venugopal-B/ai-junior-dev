# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_junior_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_junior_dev
DB_USER=postgres
DB_PASSWORD=password

# Auth
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_EXPIRES_IN=7d

# AI Provider
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=

# Redis-backed background jobs
# Use QUEUE_DRIVER=redis for a separate BullMQ worker process.
# Use QUEUE_DRIVER=memory only for simple local fallback without a separate worker.
QUEUE_DRIVER=redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
QUEUE_CONCURRENCY=2

# CORS
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
